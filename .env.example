# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LLM_PROVIDER=openai
SUPERVISOR_USE_LLM=true

REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
SEARCH_MAX_RETRIES=2

# Optional cost estimation
INPUT_TOKEN_COST_USD_PER_1K=0.15/1000.0
OUTPUT_TOKEN_COST_USD_PER_1K=0.60/1000.0
SEARCH_COST_USD_PER_CALL=0.50/1000.0


# Optional tracing providers
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
